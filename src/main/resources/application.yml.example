spring:
  datasource:
    url: jdbc:mysql://localhost:3306/interview_db?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8&allowPublicKeyRetrieval=true
    username: root
    password: your_mysql_password
    driver-class-name: com.mysql.cj.jdbc.Driver
  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    defer-datasource-initialization: true
    properties:
      hibernate:
        format_sql: true
  sql:
    init:
      mode: always

jwt:
  secret: your-jwt-secret-key-must-be-at-least-256-bits-long
  expiration: 86400000

claude:
  api-key: your_claude_api_key
  api-url: https://api.anthropic.com/v1/messages
  model: claude-haiku-4-5-20251001
